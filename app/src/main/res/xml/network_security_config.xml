<?xml version="1.0" encoding="utf-8"?>
<!--
  KaiOS packages are served over loopback HTTP and frequently talk to mixed
  http/https API endpoints. Cleartext is required for the local asset server;
  certificate pinning is intentionally not enforced so community/self-hosted
  backends keep working.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
